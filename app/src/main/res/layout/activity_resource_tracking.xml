<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:background="#C70303"
    android:orientation="vertical"
    android:layout_height="match_parent"
    tools:context=".ResourceTracking">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageView5"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/back"
            android:onClick="back"/>

        <TextView
            android:id="@+id/textView16"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:fontFamily="serif"
            android:text="Log relief distribution"
            android:textColor="@color/white"
            android:textSize="25dp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:background="@color/white"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" >

            <TextView
                android:id="@+id/textView20"
                android:layout_marginLeft="20dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Beneficiary name" />

            <EditText
                android:id="@+id/etBeneficiary"
                android:layout_width="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:textSize="13dp"
                android:layout_marginBottom="5dp"
                android:padding="15dp"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/input_border"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="Full Name"
                android:inputType="text"
                />
            <TextView
                android:id="@+id/textView203"
                android:layout_marginLeft="20dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Barangay" />

            <EditText
                android:id="@+id/etBarangay"
                android:layout_width="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:textSize="13dp"
                android:layout_marginBottom="5dp"
                android:padding="15dp"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/input_border"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="Brgy. Mabolo"
                android:inputType="text"
                />
            <TextView
                android:id="@+id/textView205"
                android:layout_marginLeft="20dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Relief type" />

            <EditText
                android:id="@+id/etRelief"
                android:layout_width="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:textSize="13dp"
                android:layout_marginBottom="5dp"
                android:padding="15dp"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/input_border"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="Food pack"
                android:inputType="text"
                />

            <TextView
                android:id="@+id/textView209"
                android:layout_marginLeft="20dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quantity" />

            <EditText
                android:id="@+id/etQuantity"
                android:layout_width="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:textSize="13dp"
                android:layout_marginBottom="5dp"
                android:padding="15dp"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/input_border"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="0"
                android:inputType="number"
                />

            <TextView
                android:id="@+id/textView207"
                android:layout_marginLeft="20dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Volunteer assigned" />

            <EditText
                android:id="@+id/etVolunteer"
                android:layout_width="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:textSize="13dp"
                android:layout_marginBottom="5dp"
                android:padding="15dp"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/input_border"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="Volunteer name"
                android:inputType="text"
                />

            <Button
                android:id="@+id/button2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="15dp"
                android:textStyle="bold"
                android:textSize="16dp"
                android:fontFamily="sans-serif"
                android:backgroundTint="#B62727"
                android:layout_marginRight="20dp"
                android:background="@drawable/button_bg"
                android:text="Log Distribution"
                android:textColor="@color/white"
                android:onClick="logClicked"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>