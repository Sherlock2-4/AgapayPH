<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#C70303"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Admin">

    <TextView
        android:id="@+id/textView16"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="10dp"
        android:fontFamily="serif"
        android:layout_width="wrap_content"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="30dp"
        android:layout_height="wrap_content"
        android:text="AgapayPH" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvName"
            android:layout_width="330dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="10dp"
            android:fontFamily="serif"
            android:text="Administrator"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/imageView4"
            android:background="@drawable/input_border"
            android:layout_width="wrap_content"
            android:layout_marginBottom="5dp"
            android:padding="5dp"
            android:backgroundTint="#F24949"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/logout"
            android:onClick="logoutClicked"
           />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:background="@color/white"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" >

            <Button
                android:id="@+id/button2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="15dp"
                android:textStyle="bold"
                android:textSize="16dp"
                android:fontFamily="sans-serif"
                android:backgroundTint="#B62727"
                android:layout_marginRight="20dp"
                android:background="@drawable/button_bg"
                android:text="+ Add evacuation center"
                android:textColor="@color/white"
                android:onClick="toAddEvacuation"/>

            <Button
                android:id="@+id/button23"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="15dp"
                android:layout_marginRight="20dp"
                android:layout_marginBottom="15dp"
                android:background="@drawable/button_bg"
                android:backgroundTint="#F06436"
                android:fontFamily="sans-serif"
                android:text="Manage Evacuation"
                android:textColor="@color/white"
                android:textSize="16dp"
                android:textStyle="bold"
                android:onClick="toManageEvacuation"/>

            <View
                android:id="@+id/view"
                android:layout_margin="5dp"
                android:background="@color/black"
                android:layout_width="300dp"
                android:layout_gravity="center"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/button22"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="15dp"
                android:textStyle="bold"
                android:textSize="16dp"
                android:fontFamily="sans-serif"
                android:backgroundTint="#B62727"
                android:layout_marginRight="20dp"
                android:background="@drawable/button_bg"
                android:text="+ Log relief distribution"
                android:textColor="@color/white"
                android:onClick="logRelief"/>

            <Button
                android:id="@+id/button24"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="15dp"
                android:textStyle="bold"
                android:textSize="16dp"
                android:fontFamily="sans-serif"
                android:backgroundTint="#F06436"
                android:layout_marginRight="20dp"
                android:background="@drawable/button_bg"
                android:text="Manage Relief"
                android:textColor="@color/white"
               />
        </LinearLayout>

    </ScrollView>
</LinearLayout>