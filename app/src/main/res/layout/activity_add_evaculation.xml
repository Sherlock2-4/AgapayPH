<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:background="#C70303"
    android:layout_height="match_parent"
    tools:context=".AddEvaculation">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageView5"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/back" />

        <TextView
            android:id="@+id/textView16"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:fontFamily="serif"
            android:text="Add Evacuation Center"
            android:textColor="@color/white"
            android:textSize="25dp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:background="@color/white"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" >
            <TextView
                android:id="@+id/textView20"
                android:layout_marginLeft="20dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Center Name" />

            <EditText
                android:layout_width="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:textSize="13dp"
                android:layout_marginBottom="5dp"
                android:padding="15dp"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/input_border"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="e.g. Brgy. Mabolo Elementary School"
                android:inputType="text"
                />

            <TextView
                android:id="@+id/textView204"
                android:layout_marginLeft="20dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Barangay" />

            <EditText
                android:layout_width="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:textSize="13dp"
                android:layout_marginBottom="5dp"
                android:padding="15dp"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/input_border"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="Brgy Mabolo"
                android:inputType="text"
                />

            <TextView
                android:id="@+id/textView205"
                android:layout_marginLeft="20dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total capacity" />

            <EditText
                android:layout_width="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:textSize="13dp"
                android:layout_marginBottom="5dp"
                android:padding="15dp"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/input_border"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="500"
                android:inputType="number"
                />

            <TextView
                android:id="@+id/textView206"
                android:layout_marginLeft="20dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Current occupancy" />

            <EditText
                android:layout_width="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:textSize="13dp"
                android:layout_marginBottom="5dp"
                android:padding="15dp"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/input_border"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="0"
                android:inputType="number"
                />

            <TextView
                android:id="@+id/textView207"
                android:layout_marginLeft="20dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Food packs available" />

            <EditText
                android:layout_width="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:textSize="13dp"
                android:layout_marginBottom="5dp"
                android:padding="15dp"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/input_border"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="100"
                android:inputType="number"
                />

            <TextView
                android:id="@+id/textView209"
                android:layout_marginLeft="20dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Water (liters)" />

            <EditText
                android:layout_width="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:textSize="13dp"
                android:layout_marginBottom="5dp"
                android:padding="15dp"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/input_border"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="200"
                android:inputType="number"
                />
            <TextView
                android:id="@+id/textView208"
                android:layout_marginLeft="20dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Medicine kits" />

            <EditText
                android:layout_width="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:textSize="13dp"
                android:layout_marginBottom="10dp"
                android:padding="15dp"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/input_border"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="50"
                android:inputType="number"
                />

            <Button
                android:id="@+id/button2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="15dp"
                android:textStyle="bold"
                android:textSize="16dp"
                android:fontFamily="sans-serif"
                android:backgroundTint="#B62727"
                android:layout_marginRight="20dp"
                android:background="@drawable/button_bg"
                android:text="Add Center"
                android:textColor="@color/white" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>