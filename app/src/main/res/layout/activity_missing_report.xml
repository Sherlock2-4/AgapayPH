<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#C70303"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MissingReport">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageView5"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/back"
            android:onClick="back"/>

        <TextView
            android:id="@+id/textView16"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:fontFamily="serif"
            android:text="Report Missing"
            android:textColor="@color/white"
            android:textSize="30dp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:background="@color/white"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" >
            <TextView
                android:id="@+id/textView20"
                android:layout_marginLeft="20dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Full Name" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:textSize="13dp"
                android:layout_marginBottom="5dp"
                android:padding="15dp"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/input_border"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="Missing person full name"
                android:inputType="text"
                />
            <TextView
                android:id="@+id/textView230"
                android:layout_marginLeft="20dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Age" />

            <EditText
                android:id="@+id/etAge"
                android:layout_width="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_marginBottom="10dp"
                android:padding="15dp"
                android:textSize="13dp"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/input_border"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="Age"
                android:inputType="number"
                />
            <TextView
                android:id="@+id/textView203"
                android:layout_marginLeft="20dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Last Know Location" />

            <EditText
                android:id="@+id/etLocation"
                android:layout_width="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_marginBottom="10dp"
                android:padding="15dp"
                android:textSize="13dp"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/input_border"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="e.g. Brgy Sta. Rita market"
                android:inputType="text"
                />
            <TextView
                android:id="@+id/textView2033"
                android:layout_marginLeft="20dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description" />

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_marginBottom="10dp"
                android:padding="15dp"
                android:textSize="13dp"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/input_border"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="Physical description, clothing, etc."
                android:inputType="text"
                />

            <Button
                android:id="@+id/button2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="15dp"
                android:textStyle="bold"
                android:textSize="16dp"
                android:fontFamily="sans-serif"
                android:backgroundTint="#B62727"
                android:layout_marginRight="20dp"
                android:background="@drawable/button_bg"
                android:text="Submit Report"
                android:textColor="@color/white"
                android:onClick="submitMissing"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>